{
  "name": "ai-career-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI Career Intelligence Platform - Enterprise-grade career recommendation system",
  "scripts": {
    "dev": "pnpm run --parallel --filter @ai-career/client --filter @ai-career/server dev",
    "build": "pnpm run --filter @ai-career/shared build && pnpm run --parallel --filter @ai-career/client --filter @ai-career/server build",
    "build:shared": "pnpm --filter @ai-career/shared build",
    "build:client": "pnpm --filter @ai-career/client build",
    "build:server": "pnpm --filter @ai-career/server build",
    "build:infra": "pnpm --filter @ai-career/infrastructure build",
    "test": "pnpm run -r test",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "pnpm run -r clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
