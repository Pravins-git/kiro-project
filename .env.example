# Server Configuration
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3000

# MongoDB (current primary database)
MONGODB_URI=mongodb://localhost:27017/ai-career-platform

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Cognito (set USE_COGNITO=true to enable Cognito auth instead of JWT)
USE_COGNITO=false
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# DynamoDB (local development)
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=ai-career-platform-dev-main

# S3 (local development via LocalStack)
S3_ENDPOINT=http://localhost:4566
S3_STAGING_BUCKET=ai-career-platform-dev-staging
S3_PRODUCTION_BUCKET=ai-career-platform-dev-production
AWS_S3_BUCKET_NAME=kiro-resumes-local

# SQS (local development via LocalStack)
SQS_ENDPOINT=http://localhost:4566
SQS_RESUME_QUEUE_URL=http://localhost:4566/000000000000/ai-career-platform-dev-resume-processing
SQS_CAREER_QUEUE_URL=http://localhost:4566/000000000000/ai-career-platform-dev-career-generation
SQS_EMBEDDING_QUEUE_URL=http://localhost:4566/000000000000/ai-career-platform-dev-embedding-generation

# SNS (local development via LocalStack)
SNS_ENDPOINT=http://localhost:4566
SNS_TOPIC_ARN=

# Textract (local development — leave empty for LocalStack)
TEXTRACT_ENDPOINT=

# Comprehend (local development — leave empty for LocalStack)
COMPREHEND_ENDPOINT=

# Secrets Manager (local development via LocalStack)
SECRETS_MANAGER_ENDPOINT=http://localhost:4566
SECRETS_MANAGER_PREFIX=ai-career-platform

# CloudWatch (local development via LocalStack)
CLOUDWATCH_ENDPOINT=http://localhost:4566
CLOUDWATCH_NAMESPACE=AICareerPlatform

# Step Functions (local development via LocalStack)
STEP_FUNCTIONS_ENDPOINT=http://localhost:4566
STEP_FUNCTIONS_RESUME_ARN=
STEP_FUNCTIONS_CAREER_ARN=

# X-Ray (set to true to enable tracing)
XRAY_ENABLED=false
XRAY_DAEMON_ADDRESS=127.0.0.1:2000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# OpenSearch (not used in local development)
OPENSEARCH_ENDPOINT=

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# OpenAI (fallback AI provider)
OPENAI_API_KEY=mock-key
